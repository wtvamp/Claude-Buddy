<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ClaudeBuddy.OrbWindow"
        Title="Claude Buddy"
        Width="56" Height="56"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        CanResize="False"
        ShowActivated="False"
        WindowStartupLocation="Manual">

    <!-- Transparent (not null) background so the whole 56x56 area is
         hit-testable: hover tooltip, drag, and right-click work anywhere
         on the orb's square, not just the ellipse pixels. -->
    <Grid x:Name="Root" Background="Transparent">
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem x:Name="SessionInfoItem" IsEnabled="False"/>
                <Separator/>
                <MenuItem Header="Reset this session to idle" Click="ResetIdle_Click"/>
                <MenuItem Header="Exit Claude Buddy" Click="Exit_Click"/>
            </ContextMenu>
        </Grid.ContextMenu>

        <!-- Soft glow behind the orb (fill assigned in code-behind, shared
             with the orb so color fades hit both) -->
        <Ellipse x:Name="Glow"
                 Width="56" Height="56"
                 Opacity="0.35">
            <Ellipse.Effect>
                <BlurEffect Radius="18"/>
            </Ellipse.Effect>
        </Ellipse>

        <!-- The buddy itself -->
        <Ellipse x:Name="Orb"
                 Width="36" Height="36"
                 Stroke="#22FFFFFF"
                 StrokeThickness="1"/>

        <!-- Folder initial so you can tell orbs apart at a glance
             (falls back to a dot until the session reports its cwd) -->
        <TextBlock x:Name="Glyph"
                   Text="&#8226;"
                   FontSize="16"
                   FontWeight="Bold"
                   Foreground="#DDFFFFFF"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   IsHitTestVisible="False"/>
    </Grid>
</Window>
