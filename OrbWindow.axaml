<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ClaudeBuddy.OrbWindow"
        Title="Claude Buddy"
        Width="56" Height="56"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        CanResize="False"
        ShowActivated="False"
        WindowStartupLocation="Manual">

    <Grid>
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Reset this session to idle" Click="ResetIdle_Click"/>
                <MenuItem Header="Exit Claude Buddy" Click="Exit_Click"/>
            </ContextMenu>
        </Grid.ContextMenu>

        <!-- Soft glow behind the orb (fill assigned in code-behind, shared
             with the orb so color fades hit both) -->
        <Ellipse x:Name="Glow"
                 Width="56" Height="56"
                 Opacity="0.35">
            <Ellipse.Effect>
                <BlurEffect Radius="18"/>
            </Ellipse.Effect>
        </Ellipse>

        <!-- The buddy itself -->
        <Ellipse x:Name="Orb"
                 Width="36" Height="36"
                 Stroke="#22FFFFFF"
                 StrokeThickness="1"/>

        <!-- Small glyph so it reads as "something", not just a dot -->
        <TextBlock x:Name="Glyph"
                   Text="&#8226;"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#DDFFFFFF"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="0,-4,0,0"
                   IsHitTestVisible="False"/>
    </Grid>
</Window>
